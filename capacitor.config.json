{
  "appId": "it.otrebor2222.carburanti",
  "appName": "Prezzi Carburanti",
  "webDir": "public",
  "bundledWebRuntime": false,
  "android": {
    "allowMixedContent": true,
    "backgroundColor": "#ffffff",
    "allowNavigation": ["https://carburanti-api.onrender.com","https://nominatim.openstreetmap.org","https://*.tile.openstreetmap.org"]
  },
  "plugins": {
    "Geolocation": {
      "permissions": ["ACCESS_COARSE_LOCATION","ACCESS_FINE_LOCATION"]
    }
  }
}
